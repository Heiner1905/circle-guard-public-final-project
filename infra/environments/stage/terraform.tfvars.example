###############################################################################
# Copy this file to terraform.tfvars and fill in the secret values before
# running `terraform plan/apply`. terraform.tfvars is gitignored so secrets
# never leave your laptop.
###############################################################################

# --- Azure (medium SKUs for stage) ------------------------------------------
azure_location = "eastus"
node_vm_size   = "Standard_B2ms"
node_min_count = 2
node_max_count = 4
acr_name       = "acrcircleguardstage"

# --- Middleware secrets (REQUIRED) ------------------------------------------
postgres_password   = "change-me-stage-pg"
neo4j_password      = "change-me-stage-neo4j"
redis_password      = "change-me-stage-redis"
ldap_admin_password = "change-me-stage-ldap"

middleware_persistence_size = "16Gi"

# --- Observability (US-10) --------------------------------------------------
enable_observability    = true
grafana_admin_password  = "change-me-stage-grafana"
dashboards_path         = ""

# --- Logging (US-11) --------------------------------------------------------
enable_logging       = true
loki_retention_hours = 168
loki_storage_size    = "16Gi"
enable_elk           = false

# --- Tracing + Alerts (US-12) -----------------------------------------------
enable_tracing           = true
jaeger_memory_max_traces = 50000
enable_alerts            = true

# --- Security (US-15) -------------------------------------------------------
# ACME with Let's Encrypt STAGING so renewals are exercised without burning
# prod rate limits. Set cluster_issuer_acme_email before applying.
enable_security             = true
application_namespace       = "circleguard"
psa_enforce_level           = "baseline"
psa_audit_level             = "restricted"
psa_warn_level              = "restricted"
enable_resource_quota       = true
resource_quota_cpu_requests = "8"
resource_quota_memory_requests = "16Gi"
resource_quota_cpu_limits   = "16"
resource_quota_memory_limits = "32Gi"
resource_quota_pods         = 50
enable_cert_manager         = true
cert_manager_chart_version  = "v1.15.3"
enable_cluster_issuer       = true
cluster_issuer_kind         = "acme"
cluster_issuer_acme_email   = "REPLACE-WITH-OPS-EMAIL"
cluster_issuer_acme_server  = "https://acme-staging-v02.api.letsencrypt.org/directory"

# --- AKS API allowlist (recomendado en stage) -------------------------------
# Pueblala con tu CIDR / VPN y, cuando esté, borra la línea AZU-0041 de
# .trivyignore para que el gate vuelva a detectar regresiones.
# api_server_authorized_ip_ranges = ["190.0.0.0/24"]

# --- AWS multi-cloud (off by default) ---------------------------------------
enable_aws             = false
aws_region             = "us-east-1"
aws_node_instance_type = "t3.medium"
aws_node_desired_size  = 2
