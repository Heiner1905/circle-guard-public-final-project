<?xml version="1.0" encoding="UTF-8"?>
<!--
  Centralized logging (US-11).
  - Local/dev/default profile: human-readable pattern with MDC slot for
    traceId/spanId so logs already look correlated once US-12 wires Jaeger.
  - kubernetes/stage/prod profiles: single-line JSON via LogstashEncoder,
    consumed by Promtail and shipped to Loki.
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty scope="context" name="appName"
                    source="spring.application.name"
                    defaultValue="circleguard-unknown"/>
    <springProperty scope="context" name="activeProfile"
                    source="spring.profiles.active"
                    defaultValue="default"/>

    <springProfile name="!kubernetes &amp; !prod &amp; !stage &amp; !dev">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [%X{traceId:-},%X{spanId:-}] %logger{36} - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="kubernetes | prod | stage | dev">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <timeZone>UTC</timeZone>
                <fieldNames>
                    <timestamp>@timestamp</timestamp>
                    <thread>thread</thread>
                    <logger>logger</logger>
                    <level>level</level>
                    <message>message</message>
                    <levelValue>[ignore]</levelValue>
                    <version>[ignore]</version>
                </fieldNames>
                <customFields>{"service":"${appName}","env":"${activeProfile}"}</customFields>
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>spanId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <includeContext>false</includeContext>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
    </springProfile>

    <logger name="com.circleguard" level="INFO"/>
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>
</configuration>
